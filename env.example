# Copy to .env and adjust.

CTFD_API_TOKEN=your_ctfd_token
DOMJUDGE_USER=admin
DOMJUDGE_PASS=your_domjudge_password

# --- CTFd + DOMjudge on the HOST (published ports) ---
# CTFD_API_URL=http://host.docker.internal:8000/api/v1
# DOMJUDGE_API_URL=http://host.docker.internal/api/v4

# --- CTFd + DOMjudge in OTHER containers (same machine) ---
# Put this bridge on their Docker network, then use service/container names:
#
#   docker network create ctf-stack
#   docker network connect ctf-stack <ctfd_container>
#   docker network connect ctf-stack <domjudge_web_container>
#   docker network connect ctf-stack htq-bridge   # after first up, or use attach file before up
#
# Easiest: add the same external network to ALL compose projects (see README).
#
# SHARED_DOCKER_NETWORK=ctf-stack
# CTFD_API_URL=http://ctfd:8000/api/v1
# DOMJUDGE_API_URL=http://domserver:80/api/v4
#
# Run bridge with:
#   docker compose -f docker-compose.yml -f docker-compose.attach.yml up -d --build
#
# Replace ctfd / domserver / ports with YOUR compose service names and internal ports.

# SQLite (Docker default: persistent volume)
# DATABASE_URL=sqlite:////data/bridge.db

# BRIDGE_PORT=5000
