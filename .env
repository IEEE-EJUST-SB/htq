# Copy to .env in this folder.

# --- Required ---
CTFD_API_TOKEN=ctfd_61e1f6d11a8d71565cb825057828a3bc80ab220ecbbc99910582feb8b760e9f7
DOMJUDGE_USER=admin
DOMJUDGE_PASS=Mohamedk@1234
# --- uvicorn on the host (CTFd + DOMjudge in Docker, ports on localhost) ---
# Uncomment when running: uvicorn main:app --port 5000
# CTFD_API_URL=http://localhost:8000/api/v1
# DOMJUDGE_API_URL=http://localhost/api/v4

# --- bridge inside Docker ---
# Compose sets API URLs to host.docker.internal automatically (do not use localhost in .env for Docker).
# Only set these if CTFd/DOMjudge are reachable another way (e.g. shared Compose network):
# BRIDGE_CTFD_API_URL=http://ctfd:8000/api/v1
# BRIDGE_DOMJUDGE_API_URL=http://domserver/api/v4

# Browser links on the admin page (your machine, not the container)
CTFD_UI_URL=http://localhost:8000
DOMJUDGE_UI_URL=http://localhost

# Optional
# BRIDGE_PORT=5000
# DATABASE_URL=sqlite:////data/bridge.db
